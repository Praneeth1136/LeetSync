# MongoDB Connection String (e.g., from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/leetsync?retryWrites=true&w=majority

# JWT Authentication Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Backend Port (Defaults to 5000)
PORT=5000

# Frontend URL for CORS configuration (Use your deployed Vercel URL in production)
FRONTEND_URL=http://localhost:5173
